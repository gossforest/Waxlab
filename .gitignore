# ─── WaxLab .gitignore ────────────────────────────────────────────────────────

# config.js is auto-generated by Netlify build from env vars.
# Commit config.js only as the empty placeholder — never with real credentials.
# The real file is written fresh on every Netlify deploy.
# Uncomment the line below once you've committed the placeholder:
# config.js

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# Node (if you ever run esbuild locally)
node_modules/
npm-debug.log*

# Local build artifacts
dist/
